NODE_ENV=development
PORT=5000

# MongoDB — replace with your Atlas URI
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/campus-health-kiosk?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRES_IN=24h

# Token expiry (minutes)
TOKEN_EXPIRY_MINUTES=30

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Email (Nodemailer — use Gmail App Password or SMTP relay)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Microsoft Azure AD (for SSO — used by frontend MSAL, not backend directly)
# AZURE_CLIENT_ID=your-azure-app-client-id
# AZURE_TENANT_ID=your-azure-tenant-id
