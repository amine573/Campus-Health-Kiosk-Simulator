{
  "version": 2,
  "projects": [
    {
      "name": "campus-health-kiosk-frontend",
      "framework": "vite",
      "rootDirectory": "frontend",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "installCommand": "npm install",
      "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
      "env": {
        "VITE_API_URL": "@chk_api_url"
      }
    }
  ]
}
